# SSO Server
SSO_SECRET_KEY=your-super-secret-key-change-this
SSO_JWT_ALGORITHM=HS256
SSO_SESSION_SECRET=another-secret-for-sessions
SSO_PORT=3010

# Consumer App
CONSUMER_PORT=3020
SSO_SERVER_URL=http://localhost:3010

# Database
DATABASE_URL=sqlite+aiosqlite:///./sso.db

# Redis (optional)
REDIS_URL=redis://localhost:6379